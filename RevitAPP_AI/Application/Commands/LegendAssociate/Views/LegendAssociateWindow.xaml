<Window x:Class="Aplication.Commands.LegendAssociate.Views.LegendAssociateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Aplication.Commands.LegendAssociate.Views"
        Title="CEG Tool - Legend Associate"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <local:NotNullToVisibilityConverter x:Key="NotNullToVisibility"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" MinWidth="380"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="7*" MinWidth="320"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- LEFT SIDE: 2 lists -->
        <GroupBox Header="View" Grid.Column="0" Grid.Row="0">
            <Grid Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding LeftHeader}" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="{Binding RightHeader}" FontWeight="Bold" Margin="0,0,0,4"/>

                <ListBox Grid.Row="1" Grid.Column="0"
                         ItemsSource="{Binding LeftItems}"
                         SelectedItem="{Binding SelectedLeftItem, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         HorizontalContentAlignment="Stretch"/>

                <ListBox Grid.Row="1" Grid.Column="2"
                         ItemsSource="{Binding RightItems}"
                         SelectedItem="{Binding SelectedRightItem, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         HorizontalContentAlignment="Stretch"/>

                <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                         Margin="0,6,0,0"
                         Padding="4,3"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tìm theo tên view / sheet number / assembly..."/>
            </Grid>
        </GroupBox>

        <!-- RIGHT SIDE: preview pane -->
        <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                BorderBrush="#888" BorderThickness="1" Background="White">
            <Grid>
                <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="6"
                       Visibility="{Binding PreviewImage, Converter={StaticResource NotNullToVisibility}}"/>
                <TextBlock Text="No preview available.&#10;Mở view một lần trong Revit để Revit tạo thumbnail."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#888" TextAlignment="Center"
                           Visibility="{Binding PreviewImage, Converter={StaticResource NullToVisibility}}"/>
            </Grid>
        </Border>

        <!-- OPTIONS row (4 group boxes) -->
        <Grid Grid.Column="0" Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="View Type" Margin="0,0,4,0">
                <StackPanel Margin="6">
                    <RadioButton Content="View" GroupName="ViewType"
                                 IsChecked="{Binding ViewTypeIsView, Mode=TwoWay}"/>
                    <RadioButton Content="Legend" GroupName="ViewType"
                                 IsChecked="{Binding ViewTypeIsLegend, Mode=TwoWay}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Select by" Margin="2,0,2,0">
                <StackPanel Margin="6">
                    <RadioButton Content="View/Legend" GroupName="SelectBy"
                                 IsChecked="{Binding SelectByView, Mode=TwoWay}"/>
                    <RadioButton Content="Sheet" GroupName="SelectBy"
                                 IsChecked="{Binding SelectBySheet, Mode=TwoWay}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Find" Margin="2,0,2,0">
                <StackPanel Margin="6">
                    <RadioButton Content="View/Legend in sheets" IsChecked="True" IsEnabled="False"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="3" Header="Preview" Margin="4,0,0,0">
                <StackPanel Margin="6">
                    <RadioButton Content="Legend Preview" GroupName="Preview"
                                 IsChecked="{Binding PreviewIsLegend, Mode=TwoWay}"/>
                    <RadioButton Content="Sheet Preview" GroupName="Preview"
                                 IsChecked="{Binding PreviewIsSheet, Mode=TwoWay}"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ACTIONS row -->
        <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Refresh" Padding="10,5" Margin="4,0"
                    Command="{Binding RefreshCommand}"/>
            <Button Content="Replace in Sheet" Padding="10,5" Margin="4,0"
                    Command="{Binding ReplaceCommand}"/>
            <Button Content="Insert View" Padding="10,5" Margin="4,0"
                    Command="{Binding InsertCommand}"/>
            <Button Content="Duplicate and Insert View" Padding="10,5" Margin="4,0"
                    Command="{Binding DuplicateInsertCommand}"/>
            <Button Content="Go To View/Sheet" Padding="10,5" Margin="4,0"
                    Command="{Binding GoToCommand}"/>
            <Button Content="Close" Padding="10,5" Margin="4,0"
                    Command="{Binding CloseCommand}" IsCancel="True"/>
        </StackPanel>

        <!-- STATUS bar -->
        <TextBlock Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="3"
                   Text="{Binding StatusMessage}" Margin="0,6,0,0"
                   Foreground="#555" FontStyle="Italic"/>
    </Grid>
</Window>
