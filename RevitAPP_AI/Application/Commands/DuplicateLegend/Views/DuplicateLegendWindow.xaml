<Window x:Class="Aplication.Commands.DuplicateLegend.Views.DuplicateLegendWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Duplicate Legends"
        Width="380"
        Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LabelCount" Grid.Row="0" Margin="0,0,0,10" FontSize="13"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="OnDuplicateClick"
                    IsDefault="True"
                    Padding="8,6">
                <StackPanel>
                    <TextBlock Text="Duplicate" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="(xếp ngang, cách 10mm)" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Click="OnReplaceClick"
                    Padding="8,6">
                <StackPanel>
                    <TextBlock Text="Replace" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="(thay tại vị trí gốc)" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Hidden cancel button so ESC closes the dialog -->
            <Button IsCancel="True" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
