<Window x:Class="Aplication.Commands.ExportCAD.Views.ExportCADWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Aplication.Commands.ExportCAD.ViewModels"
        Title="Export CAD (Merged) — MV_tool"
        Width="560"
        Height="700"
        MinWidth="440"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="#FFFFFF">
    <Window.Resources>
        <!-- ====== Palette ====== -->
        <SolidColorBrush x:Key="AccentBrush" Color="#A02828"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#882020"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#8A8A8A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GroupHeaderBrush" Color="#F4F4F4"/>

        <!-- ====== TextBox phẳng có placeholder ====== -->
        <Style x:Key="FlatTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- ====== Button thường ====== -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F4F4F4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====== Nút Export nổi bật (Accent) ====== -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====== Template cho 1 dòng view ====== -->
        <DataTemplate DataType="{x:Type vm:ExportViewItemViewModel}">
            <StackPanel Orientation="Horizontal" Margin="2,3">
                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- ====== Group header (Sheets, Floor Plans, ...) ====== -->
        <Style x:Key="GroupHeaderStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <Expander IsExpanded="True"
                                  Background="{StaticResource GroupHeaderBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="0,0,0,1"
                                  Margin="0,2,0,2">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="#444444"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0">
                                        <Run Text="("/><Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter Margin="18,2,0,4"/>
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header mô tả tính năng -->
        <TextBlock Grid.Row="0"
                   Text="Chọn sheet/view để gộp vào MỘT file DWG. Vị trí và tỷ lệ của các view được giữ nguyên như trong Revit."
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,0,0,10"/>

        <!-- Row 1: Search box -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <TextBox x:Name="SearchTextBox"
                     Style="{StaticResource FlatTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Search view / sheet name..."
                       Foreground="{StaticResource MutedBrush}"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Row 2: Check All / None + Total count -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource FlatButton}"
                    Content="Check All"
                    Command="{Binding CheckAllCommand}"
                    Margin="0,0,6,0"/>
            <Button Grid.Column="1"
                    Style="{StaticResource FlatButton}"
                    Content="Check None"
                    Command="{Binding CheckNoneCommand}"/>

            <TextBlock Grid.Column="3"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}">
                <Run Text="{Binding TotalCount, Mode=OneWay}"/><Run Text=" item(s)"/>
            </TextBlock>
        </Grid>

        <!-- Row 3: Danh sách view group by GroupLabel -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Background="{StaticResource PanelBrush}">
            <ListBox ItemsSource="{Binding FilteredItems}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     HorizontalContentAlignment="Stretch"
                     SelectionMode="Single"
                     Padding="6">
                <ListBox.GroupStyle>
                    <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}"/>
                </ListBox.GroupStyle>
            </ListBox>
        </Border>

        <!-- Row 4: Footer (Export + Cancel) -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Style="{StaticResource AccentButton}"
                    Content="{Binding ExportButtonText}"
                    Command="{Binding ExportCommand}"
                    MinWidth="120"
                    IsDefault="True"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Style="{StaticResource FlatButton}"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    MinWidth="90"
                    Padding="20,8"
                    IsCancel="True">
                <Button.Foreground>
                    <SolidColorBrush Color="#A02828"/>
                </Button.Foreground>
                <Button.BorderBrush>
                    <SolidColorBrush Color="#A02828"/>
                </Button.BorderBrush>
            </Button>
        </Grid>
    </Grid>
</Window>
